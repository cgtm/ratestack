{
  "name": "ratestack",
  "description": "Fast, minimal currency converter PWA for mobile homescreens.",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "author": "Cam McVey <cam.mcvey@gmail.com",
  "license": "MIT",
  "homepage": "https://cgtm.github.io/ratestack/",
  "repository": {
    "type": "git",
    "url": "https://github.com/cgtm/ratestack.git"
  },
  "bugs": {
    "url": "https://github.com/cgtm/ratestack/issues"
  },
  "keywords": [
    "currency",
    "converter",
    "pwa",
    "exchange-rates"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks && git config push.followTags true && git config alias.c '!npm run commit --'",
    "commit": "node scripts/commit.mjs",
    "dev": "python3 -m http.server 8080",
    "build:css": "tailwindcss -i src/styles.css -o style.css --minify",
    "build:sw": "node scripts/generate-sw.mjs",
    "build": "npm run build:css && npm run build:sw",
    "format": "npx --yes prettier@3.5.3 --write .",
    "format:check": "npx --yes prettier@3.5.3 --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/cli": "^4.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.8.9",
    "tailwindcss": "^4.2.2",
    "vitest": "^3.1.1"
  }
}
