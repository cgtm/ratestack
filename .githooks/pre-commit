#!/bin/sh
set -e
npm run format
git add -u

# Bump version if commit message contains [patch|minor|major]
COMMIT_MSG_FILE="${GIT_DIR:-.git}/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
  MSG=$(cat "$COMMIT_MSG_FILE")
  if echo "$MSG" | grep -qE '\[(patch|minor|major)\]'; then
    if ! git diff --cached --name-only | grep -q "^package\.json$"; then
      BUMP=$(echo "$MSG" | grep -oE '\[(patch|minor|major)\]' | head -1 | tr -d '[]')
      npm version "$BUMP" --no-git-tag-version --silent
      git add package.json package-lock.json
    fi
  fi
fi

npm test
