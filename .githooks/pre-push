#!/bin/sh
set -e

# Don't version-bump when pushing tags (avoid re-entry)
while IFS=' ' read -r local_ref _rest; do
  case "$local_ref" in refs/tags/*) exit 0 ;; esac
done

MSG=$(git log -1 --format='%s')

if echo "$MSG" | grep -q '\[major\]'; then
  BUMP=major
elif echo "$MSG" | grep -q '\[minor\]'; then
  BUMP=minor
elif echo "$MSG" | grep -q '\[patch\]'; then
  BUMP=patch
else
  exit 0
fi

npm version "$BUMP" --no-git-tag-version
NEW_VERSION=$(node -p "require('./package.json').version")
git add package.json package-lock.json
git commit --amend --no-edit --no-verify
git tag "v${NEW_VERSION}"
git push origin "v${NEW_VERSION}"
echo "Bumped to v${NEW_VERSION} and tagged."
