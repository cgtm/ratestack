#!/bin/sh
set -e
MSG=$(cat "$1")

if echo "$MSG" | grep -q '\[major\]'; then
  BUMP=major
elif echo "$MSG" | grep -q '\[minor\]'; then
  BUMP=minor
elif echo "$MSG" | grep -q '\[patch\]'; then
  BUMP=patch
else
  exit 0
fi

# Skip if version was already bumped (e.g. on --amend)
CURRENT=$(node -p "require('./package.json').version")
LATEST=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || echo "0.0.0")
if [ "$CURRENT" != "$LATEST" ]; then
  exit 0
fi

npm version "$BUMP" --no-git-tag-version
git add package.json package-lock.json
